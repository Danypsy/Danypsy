# Configuration de la base de données
DATABASE_URL="postgresql://user:password@localhost:5432/aif_csp?schema=public"

# Configuration JWT
JWT_SECRET="votre_secret_jwt_tres_securise_a_changer"
JWT_EXPIRES_IN="7d"

# Configuration serveur
PORT=3000
NODE_ENV="development"

# Configuration email (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="votre_email@example.com"
SMTP_PASSWORD="votre_mot_de_passe"
EMAIL_FROM="noreply@aif-csp.fr"

# Configuration CORS
CORS_ORIGIN="http://localhost:3001"

# Configuration rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# URL frontend (pour les liens dans les emails)
FRONTEND_URL="http://localhost:3001"

# Configuration stockage fichiers
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
